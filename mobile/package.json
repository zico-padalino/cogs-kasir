{
  "name": "cogs-kasir-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "build:apk": "eas build --platform android --profile preview",
    "build:aab": "eas build --platform android --profile production",
    "build:apk:local": "expo prebuild --platform android --clean && cd android && gradlew.bat assembleRelease && cd .."
  },
  "dependencies": {
    "@expo-google-fonts/instrument-sans": "^0.4.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.36",
    "expo-asset": "~12.0.13",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-speech": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "^0.81.5",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.2",
    "react-native-webview": "^13.15.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  }
}
